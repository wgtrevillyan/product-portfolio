{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/companies/:slug",
      "destination": "/detail_companies.html"
    },
    {
      "source": "/patents/:slug",
      "destination": "/detail_patents.html"
    },
    {
      "source": "/products/clip-nexus",
      "destination": "/product_pages/clip-nexus.html"
    },
    {
      "source": "/products/clip360",
      "destination": "/product_pages/clip360.html"
    },
    {
      "source": "/products/propertycareplus",
      "destination": "/product_pages/propertycareplus.html"
    },
    {
      "source": "/products/clip-telescript",
      "destination": "/product_pages/clip-telescript.html"
    },
    {
      "source": "/products/owner-hub",
      "destination": "/product_pages/owner-hub.html"
    },
    {
      "source": "/products/verbaly-web-app",
      "destination": "/product_pages/verbaly-web-app.html"
    },
    {
      "source": "/products/incode-analytics",
      "destination": "/product_pages/incode-analytics.html"
    },
    {
      "source": "/products/appfolio-sync",
      "destination": "/product_pages/appfolio-sync.html"
    },
    {
      "source": "/products/water-monitor",
      "destination": "/product_pages/water-monitor.html"
    },
    {
      "source": "/products/incode-forms",
      "destination": "/product_pages/incode-forms.html"
    },
    {
      "source": "/products/incode-concierge",
      "destination": "/product_pages/incode-concierge.html"
    },
    {
      "source": "/products/newsnook",
      "destination": "/product_pages/newsnook.html"
    },
    {
      "source": "/products/speech-analysis-api",
      "destination": "/product_pages/speech-analysis-api.html"
    },
    {
      "source": "/products",
      "destination": "/products.html"
    },
    {
      "source": "/patents",
      "destination": "/patents.html"
    },
    {
      "source": "/companies",
      "destination": "/companies.html"
    },
    {
      "source": "/let-us-chat",
      "destination": "/let-us-chat.html"
    },
    {
      "source": "/detail_products",
      "destination": "/detail_products.html"
    },
    {
      "source": "/detail_patents",
      "destination": "/detail_patents.html"
    },
    {
      "source": "/detail_companies",
      "destination": "/detail_companies.html"
    },
    {
      "source": "/detail_skills",
      "destination": "/detail_skills.html"
    },
    {
      "source": "/detail_tags",
      "destination": "/detail_tags.html"
    },
    {
      "source": "/detail_product-images",
      "destination": "/detail_product-images.html"
    },
    {
      "source": "/404",
      "destination": "/404.html"
    },
    {
      "source": "/401",
      "destination": "/401.html"
    }
  ]
}
